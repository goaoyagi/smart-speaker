# Audio Devices
MIC_DEVICE=hw:0,0
SPEAKER_DEVICE=plughw:0,0

# Audio Recording
SAMPLE_RATE=16000
CHANNELS=1
RECORD_SECONDS=10

# Whisper Configuration
WHISPER_MODEL_SIZE=small

# Piper TTS Configuration
PIPER_MODEL_PATH=./models/tsukuyomi.onnx
PIPER_CONFIG_PATH=./models/config.json

# Status LED (GPIO) settings
STATUS_LED_ENABLED=true
STATUS_LED_PIN=23

# Push-to-talk (GPIO button) settings
PUSH_TO_TALK_ENABLED=true
PTT_BUTTON_PIN=24
PTT_BOUNCE_TIME=0.05
PTT_MIN_RECORD_SECONDS=0.5
PTT_MAX_RECORD_SECONDS=30

# Conversation history (multi-turn dialogue) settings
CONVERSATION_MAX_TURNS=3
CONVERSATION_ANSWER_CLIP=200

# Debug (optional: set to save recorded audio for analysis)
# DEBUG_AUDIO_DIR=./debug

# SearXNG Configuration
SEARXNG_URL=http://localhost:8080

# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b
