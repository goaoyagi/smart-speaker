# Audio Devices
MIC_DEVICE=hw:0,0
SPEAKER_DEVICE=plughw:0,0

# Audio Recording
SAMPLE_RATE=16000
CHANNELS=1
RECORD_SECONDS=10

# Whisper Configuration
WHISPER_MODEL_SIZE=small

# Piper TTS Configuration
PIPER_MODEL_PATH=./models/tsukuyomi.onnx
PIPER_CONFIG_PATH=./models/config.json

# Status LED (GPIO) settings
STATUS_LED_ENABLED=true
STATUS_LED_PIN=17

# Debug (optional: set to save recorded audio for analysis)
# DEBUG_AUDIO_DIR=./debug

# SearXNG Configuration
SEARXNG_URL=http://localhost:8080

# Ollama Configuration
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen2.5:3b
